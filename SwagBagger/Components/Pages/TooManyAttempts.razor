@page "/too-many-attempts"
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]

<PageTitle>Too Many Attempts - SwagBagger</PageTitle>

<div class="status-page">
    <i class="bi bi-hourglass-split status-icon"></i>
    <h1>Too Many Attempts</h1>
    <p class="status-subtitle">You've made too many login attempts. Please wait a minute and try again.</p>

    <a href="/login" class="btn btn-primary mt-3">Back to Login</a>
</div>