@page "/"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@implements IDisposable
@inject SwagBagger.Services.QBittorrentClient QBittorrentClient
@inject SwagBagger.Services.ProwlarrClient ProwlarrClient
@inject SwagBagger.Services.MediaPathBuilder MediaPathBuilder
@inject SwagBagger.Services.MagnetLinkParser MagnetLinkParser
@inject SwagBagger.Services.TorrentMonitorService TorrentMonitorService

<PageTitle>SwagBagger</PageTitle>

<div class="submit-card">
    <h2>Add Download</h2>

    <form @onsubmit="SubmitAsync" class="submit-form">
        <div class="mb-3 form-check form-switch">
            <input type="checkbox" id="manualEntryToggle" class="form-check-input toggle-switch-green" checked="@ManualEntry" @onchange="ToggleManualEntry" />
            <label for="manualEntryToggle" class="form-check-label">Enter magnet link manually</label>
        </div>

        @if (ManualEntry)
        {
            <div class="mb-3">
                <label for="magnetLink" class="form-label">Magnet Link</label>
                <textarea id="magnetLink" @bind="MagnetLink" class="form-control" rows="2" placeholder="magnet:?xt=urn:btih:..."></textarea>
            </div>
        }
        else
        {
            <div class="mb-3">
                <label for="torrentSearch" class="form-label">Search Torrents</label>
                <div class="input-group">
                    <input type="text" id="torrentSearch" @bind="SearchQuery" @bind:event="oninput" @onkeydown="HandleSearchKeyDown" class="form-control" placeholder="Search for a torrent..." />
                    <button type="button" class="btn btn-secondary" @onclick="SearchAsync" disabled="@IsSearching">@(IsSearching ? "Searching..." : "Search")</button>
                </div>
            </div>

            @if (SearchError is not null)
            {
                <p class="submit-error">@SearchError</p>
            }

            @if (SearchResults.Count > 0)
            {
                <div class="table-responsive mb-3">
                    <table class="table table-sm table-hover">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Indexer</th>
                                <th>Size</th>
                                <th>Seeders</th>
                                <th>Leechers</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (SwagBagger.Models.TorrentSearchResult result in PagedResults)
                            {
                                <tr class="selectable-row @(IsSelected(result) ? "selected-row" : "")" @onclick="() => SelectResult(result)">
                                    <td class="text-truncate" style="max-width: 400px;">@result.Title</td>
                                    <td>@result.Indexer</td>
                                    <td>@FormatBytes(result.Size)</td>
                                    <td>@result.Seeders</td>
                                    <td>@result.Leechers</td>
                                </tr>
                            }
                            @for (int i = PagedResults.Count(); i < ResultsPerPage; i++)
                            {
                                <tr class="filler-row">
                                    <td>&nbsp;</td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="PreviousPage" disabled="@(CurrentPage == 0)">Previous</button>
                    <span>Page @(CurrentPage + 1) of @TotalPages</span>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="NextPage" disabled="@(CurrentPage >= TotalPages - 1)">Next</button>
                </div>
            }

            @if (!string.IsNullOrEmpty(MagnetLink))
            {
                <p class="text-muted">Selected: @SelectedTitle</p>
            }
        }

        @if (SelectedType == SwagBagger.Models.MediaType.Movie)
        {
            <div class="row">
                <div class="col-md-3 mb-3">
                    <label for="mediaType" class="form-label">Type</label>
                    <select id="mediaType" @bind="SelectedType" class="form-select">
                        <option value="@SwagBagger.Models.MediaType.Movie">Movie</option>
                        <option value="@SwagBagger.Models.MediaType.Tv">TV Show</option>
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label for="movieName" class="form-label">Movie Name</label>
                    <input type="text" id="movieName" @bind="MovieName" class="form-control" required />
                </div>
                <div class="col-md-3 mb-3">
                    <label for="movieYear" class="form-label">Release Year</label>
                    <input type="number" id="movieYear" @bind="MovieYear" class="form-control" />
                </div>
            </div>
        }
        else
        {
            <div class="row">
                <div class="col-md-3 mb-3">
                    <label for="mediaType" class="form-label">Type</label>
                    <select id="mediaType" @bind="SelectedType" class="form-select">
                        <option value="@SwagBagger.Models.MediaType.Movie">Movie</option>
                        <option value="@SwagBagger.Models.MediaType.Tv">TV Show</option>
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label for="showName" class="form-label">Show Name</label>
                    <input type="text" id="showName" @bind="ShowName" class="form-control" required />
                </div>
                <div class="col-md-3 mb-3">
                    <label for="seasonNumber" class="form-label">Season Number</label>
                    <input type="number" id="seasonNumber" @bind="SeasonNumber" class="form-control" />
                </div>
            </div>
        }

        <button type="submit" class="btn btn-primary">Submit</button>

        @if (SubmitError is not null)
        {
            <p class="submit-error">@SubmitError</p>
        }
    </form>
</div>

<div class="downloads-card">
    <h2>Downloads</h2>

    @{
        List<SwagBagger.Models.TorrentInfo> displayTorrents = TorrentMonitorService.GetDisplayTorrents().ToList();
    }

    @if (displayTorrents.Count == 0)
    {
        <p class="text-muted">No active downloads.</p>
    }
    else
    {
        @foreach (SwagBagger.Models.TorrentInfo torrent in displayTorrents)
        {
            bool moving = TorrentMonitorService.IsMoving(torrent.Hash);
            double displayProgress = moving ? TorrentMonitorService.GetMoveProgress(torrent.Hash) : torrent.Progress;
            <div class="download-item">
                <div class="download-item-top">
                    <div class="download-item-names">
                        <div class="download-field">
                            <span class="download-label">Requested Name</span>
                            <span class="download-value">@(TorrentMonitorService.GetDisplayName(torrent.Hash) ?? "-")</span>
                        </div>
                        <div class="download-field">
                            <span class="download-label">Torrent Name</span>
                            <span class="download-value text-truncate">@torrent.Name</span>
                        </div>
                    </div>

                    <div class="download-item-stats">
                        <div class="download-field">
                            <span class="download-label">Status</span>
                            <span class="download-value">
                                <span class="status-badge @(moving ? "status-moving" : GetStatusClass(torrent.State))">
                                    @(moving ? "Moving" : GetStatusLabel(torrent.State))
                                </span>
                            </span>
                        </div>
                        <div class="download-field">
                            <span class="download-label">Size</span>
                            <span class="download-value">@FormatBytes(torrent.Size)</span>
                        </div>
                        <div class="download-field">
                            <span class="download-label">Speed</span>
                            <span class="download-value">@(moving ? "-" : FormatSpeed(torrent.DownloadSpeed))</span>
                        </div>
                        <div class="download-field">
                            <span class="download-label">Seeds</span>
                            <span class="download-value">@(moving ? "-" : torrent.NumSeeds.ToString())</span>
                        </div>
                    </div>
                </div>

                <div class="progress-track">
                    <div class="progress-fill @(moving ? "progress-fill-moving" : "")" style="width: @($"{displayProgress:P0}")"></div>
                    <span class="progress-label">@($"{displayProgress:P0}")</span>
                </div>
            </div>
        }
    }
</div>

@code {
    /// <summary>
    /// The magnet link entered by the user, or populated automatically when a search result is selected.
    /// </summary>
    private string MagnetLink { get; set; } = string.Empty;

    /// <summary>
    /// Whether the submission is a movie or a TV show.
    /// </summary>
    private SwagBagger.Models.MediaType SelectedType { get; set; } = SwagBagger.Models.MediaType.Movie;

    /// <summary>
    /// The movie's title, used when <see cref="SelectedType"/> is Movie.
    /// </summary>
    private string MovieName { get; set; } = string.Empty;

    /// <summary>
    /// The movie's release year, used when <see cref="SelectedType"/> is Movie.
    /// </summary>
    private int MovieYear { get; set; } = DateTime.Now.Year;

    /// <summary>
    /// The show's title, used when <see cref="SelectedType"/> is Tv.
    /// </summary>
    private string ShowName { get; set; } = string.Empty;

    /// <summary>
    /// The season number, used when <see cref="SelectedType"/> is Tv.
    /// </summary>
    private int SeasonNumber { get; set; } = 1;

    /// <summary>
    /// An error message to display if submission fails, or null if there is no error.
    /// </summary>
    private string? SubmitError { get; set; }

    /// <summary>
    /// Whether the user is entering a magnet link manually, rather than searching for a torrent. Defaults to false so search is the default entry mode.
    /// </summary>
    private bool ManualEntry { get; set; }

    /// <summary>
    /// The term currently entered in the torrent search box.
    /// </summary>
    private string SearchQuery { get; set; } = string.Empty;

    /// <summary>
    /// Whether a search request is currently in progress.
    /// </summary>
    private bool IsSearching { get; set; }

    /// <summary>
    /// An error message to display if a search fails, or null if there is no error.
    /// </summary>
    private string? SearchError { get; set; }

    /// <summary>
    /// The full set of results from the most recent search, ordered by seeders descending.
    /// </summary>
    private List<SwagBagger.Models.TorrentSearchResult> SearchResults { get; set; } = [];

    /// <summary>
    /// The title of the currently selected search result, shown to confirm the user's choice.
    /// </summary>
    private string? SelectedTitle { get; set; }

    /// <summary>
    /// The zero-based index of the currently displayed page of search results.
    /// </summary>
    private int CurrentPage { get; set; }

    /// <summary>
    /// The number of search results shown per page.
    /// </summary>
    private const int ResultsPerPage = 10;

    /// <summary>
    /// The total number of pages available for the current set of search results.
    /// </summary>
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(SearchResults.Count / (double)ResultsPerPage));

    /// <summary>
    /// The subset of search results to display on the current page.
    /// </summary>
    private IEnumerable<SwagBagger.Models.TorrentSearchResult> PagedResults => SearchResults.Skip(CurrentPage * ResultsPerPage).Take(ResultsPerPage);

    /// <summary>
    /// Subscribes to torrent status updates so the page redraws whenever the background monitor polls qBittorrent or a move starts or finishes.
    /// </summary>
    protected override void OnInitialized()
    {
        TorrentMonitorService.StatusChanged += HandleStatusChanged;
    }

    /// <summary>
    /// Toggles between search mode and manual magnet entry mode, clearing state left over from whichever mode is being left.
    /// </summary>
    private void ToggleManualEntry(ChangeEventArgs e)
    {
        ManualEntry = e.Value is true;
        MagnetLink = string.Empty;
        SelectedTitle = null;
        SearchResults = [];
        CurrentPage = 0;
    }

    /// <summary>
    /// Searches Prowlarr for the current query and resets pagination to the first page of results.
    /// </summary>
    private async Task SearchAsync()
    {
        if (string.IsNullOrWhiteSpace(SearchQuery))
        {
            return;
        }

        IsSearching = true;
        SearchError = null;
        StateHasChanged();

        try
        {
            SearchResults = await ProwlarrClient.SearchAsync(SearchQuery);
            CurrentPage = 0;
        }
        catch (Exception ex)
        {
            SearchError = $"Search failed: {ex.Message}";
            SearchResults = [];
        }
        finally
        {
            IsSearching = false;
        }
    }

    /// <summary>
    /// Runs a search when the user presses Enter in the search box.
    /// </summary>
    /// <param name="e">The keyboard event arguments.</param>
    private async Task HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SearchAsync();
        }
    }

    /// <summary>
    /// Selects a search result, populating the magnet link from it, preferring a magnet URL over a download URL if both are present.
    /// </summary>
    /// <param name="result">The search result the user selected.</param>
    private void SelectResult(SwagBagger.Models.TorrentSearchResult result)
    {
        MagnetLink = result.MagnetUrl ?? result.DownloadUrl ?? string.Empty;
        SelectedTitle = result.Title;
    }

    /// <summary>
    /// Determines whether the given search result is the currently selected one.
    /// </summary>
    /// <param name="result">The search result to check.</param>
    private bool IsSelected(SwagBagger.Models.TorrentSearchResult result) => SelectedTitle == result.Title;

    /// <summary>
    /// Moves to the previous page of search results, if not already on the first page.
    /// </summary>
    private void PreviousPage()
    {
        if (CurrentPage > 0)
        {
            CurrentPage--;
        }
    }

    /// <summary>
    /// Moves to the next page of search results, if not already on the last page.
    /// </summary>
    private void NextPage()
    {
        if (CurrentPage < TotalPages - 1)
        {
            CurrentPage++;
        }
    }

    /// <summary>
    /// Extracts the magnet link's hash, builds the Plex destination path, adds the magnet to qBittorrent, and registers the destination for later use by the background monitor.
    /// </summary>
    private async Task SubmitAsync()
    {
        SubmitError = null;

        // Extract the info hash from the magnet link, used as the key to register the destination path
        string? hash = MagnetLinkParser.ExtractHash(MagnetLink);
        if (hash is null)
        {
            SubmitError = "Could not extract a hash from that magnet link. Check it is a valid magnet link.";
            return;
        }

        // Build the Plex-compliant destination folder based on the selected media type
        string destinationPath = SelectedType == SwagBagger.Models.MediaType.Movie
            ? MediaPathBuilder.BuildMoviePath(MovieName, MovieYear)
            : MediaPathBuilder.BuildTvPath(ShowName, SeasonNumber);

        // Add the magnet to qBittorrent and register where it should end up once complete
        await QBittorrentClient.AddMagnetAsync(MagnetLink);
        string displayName = SelectedType == SwagBagger.Models.MediaType.Movie ? MovieName : ShowName;
        TorrentMonitorService.RegisterDestination(hash, destinationPath, displayName);

        // Reset the form for the next submission
        MagnetLink = string.Empty;
        MovieName = string.Empty;
        ShowName = string.Empty;
        SelectedTitle = null;
        SearchResults = [];
        SearchQuery = string.Empty;
        CurrentPage = 0;
    }

    /// <summary>
    /// Invoked when the background monitor reports updated torrent status; triggers a re-render via the Blazor dispatcher.
    /// </summary>
    private void HandleStatusChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Maps a qBittorrent state string to a CSS class for the status badge.
    /// </summary>
    /// <param name="state">The raw qBittorrent state string.</param>
    private static string GetStatusClass(string state) => state switch
    {
        "downloading" or "metaDL" or "forcedDL" => "status-downloading",
        "stalledUP" or "uploading" or "forcedUP" => "status-seeding",
        "error" or "missingFiles" => "status-error",
        "pausedDL" or "pausedUP" => "status-paused",
        _ => "status-default"
    };

    /// <summary>
    /// Maps a qBittorrent state string to a human-friendly display label.
    /// </summary>
    /// <param name="state">The raw qBittorrent state string.</param>
    private static string GetStatusLabel(string state) => state switch
    {
        "downloading" => "Downloading",
        "metaDL" => "Fetching Metadata",
        "forcedDL" => "Downloading",
        "stalledUP" => "Seeding",
        "uploading" => "Seeding",
        "forcedUP" => "Seeding",
        "error" => "Error",
        "missingFiles" => "Missing Files",
        "pausedDL" => "Paused",
        "pausedUP" => "Paused",
        "queuedDL" => "Queued",
        "queuedUP" => "Queued",
        "checkingDL" => "Checking",
        "checkingUP" => "Checking",
        "allocating" => "Allocating",
        "stalledDL" => "Stalled",
        _ => state
    };

    /// <summary>
    /// Formats a byte count as a human-readable size string, e.g. "1.4 GB".
    /// </summary>
    /// <param name="bytes">The size in bytes.</param>
    private static string FormatBytes(long bytes)
    {
        string[] units = ["B", "KB", "MB", "GB", "TB"];
        double size = bytes;
        int unitIndex = 0;
        while (size >= 1024 && unitIndex < units.Length - 1)
        {
            size /= 1024;
            unitIndex++;
        }
        return $"{size:0.#}{units[unitIndex]}";
    }

    /// <summary>
    /// Formats a byte-per-second speed as a human-readable string, e.g. "1.4 MB/s".
    /// </summary>
    /// <param name="bytesPerSecond">The speed in bytes per second.</param>
    private static string FormatSpeed(long bytesPerSecond) => $"{FormatBytes(bytesPerSecond)}/s";

    /// <summary>
    /// Unsubscribes from torrent status updates when the component is disposed, to avoid a memory leak.
    /// </summary>
    public void Dispose()
    {
        TorrentMonitorService.StatusChanged -= HandleStatusChanged;
    }
}